{
  "name": "newsletter",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy ${WRANGLER_CONFIG:+--config $WRANGLER_CONFIG} --var DEPLOY_SHA:$(git rev-parse --short HEAD)",
    "test": "vitest run",
    "lint": "eslint worker scripts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "check:public-identifiers": "tsx scripts/check-public-identifiers.ts",
    "check:docs": "tsx scripts/check-docs.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250506.0",
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.14.0",
    "eslint": "^9.25.0",
    "marked": "^18.0.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2",
    "wrangler": "^4.14.0"
  }
}
